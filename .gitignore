# Python virtual environment (VERY IMPORTANT - excludes your venv folder)
venv/
env/
ENV/
.env/
.venv/

# Python cache files (generated automatically, should not be versioned)
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Compiled files
*.egg
*.egg-info/
dist/
build/
*.exe

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter notebooks (if you use them for testing)
.ipynb_checkpoints/
*.ipynb

# Logs and databases
*.log
*.sqlite
*.db

# Streamlit secrets (never commit sensitive data!)
.streamlit/secrets.toml
.streamlit/config.toml

# Data files (optional - exclude if data is large or sensitive)
*.csv
*.xlsx
*.xls
!sample_data.csv    # This allows a sample data file if you want to include one

# Testing
.pytest_cache/
.coverage
htmlcov/

# OS generated files
Thumbs.db
desktop.ini